# AWS SSO プロファイル名
# `aws sso login --profile <この値>` で認証する
aws-profile-name=your-profile-name

# サイトのログインパスワード
# ユーザがブラウザでアクセスした際に入力するパスワード
site-password=your-password

# HMAC シークレットキー
# パスワード認証後に発行する Cookie (music_auth) の署名に使用する
# 任意のランダム文字列を設定する（例: openssl rand -hex 32 で生成）
hmac-secret=your-hmac-secret
